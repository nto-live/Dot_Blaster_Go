# =============================================================================
# Dot Blaster Go - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# cc65 toolchain (not tracked - see README for setup)
# -----------------------------------------------------------------------------
cc65/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
*.nes
*.o
*.s
*.lbl
*.map
*.dbg
*.lib
*.a

# -----------------------------------------------------------------------------
# cc65 intermediate / listing files
# -----------------------------------------------------------------------------
*.lst
*.dep

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# macOS (in case anyone builds on a Mac)
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Visual Studio / VS Code
# -----------------------------------------------------------------------------
.vscode/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.user

# -----------------------------------------------------------------------------
# CLion / JetBrains
# -----------------------------------------------------------------------------
.idea/
cmake-build-*/

# -----------------------------------------------------------------------------
# Vim / Emacs / other editors
# -----------------------------------------------------------------------------
*~
*.swp
*.swo
*.bak
*.orig
\#*\#
.#*

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
